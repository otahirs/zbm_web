{% if photo %}
<div class="contact-trainer">
<a class="contact-photo-link" data-full="{{ page.route() }}/{{ photo }}.png"><img src="{{ page.route() }}/{{ photo }}-thumb.jpg" alt="{{ name }}" class="contact-trainer__photo img-fluid rounded-circle"></a>
<div class="contact-trainer__info">
{% endif %}
<h4>{{ name }}</h4>
<ul class="fa-ul{% if phone %} mb-4{% endif %}">
    {% if phone %}<li><i class="fa-li fa fa-phone"></i>{{ phone }}</li>{% endif %}
    <li><i class="fa-li fa fa-envelope"></i>{{ email }}</li>
</ul>
{% if photo %}
</div>
</div>
{% endif %}
